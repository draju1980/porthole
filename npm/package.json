{
  "name": "porthole-sandbox",
  "version": "0.1.3",
  "description": "Node-native local sandbox runtime with HTTP inspection and Cloudflare tunnel exposure",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test tests/sandbox.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/draju1980/porthole.git",
    "directory": "npm"
  },
  "homepage": "https://github.com/draju1980/porthole#readme",
  "bugs": {
    "url": "https://github.com/draju1980/porthole/issues"
  },
  "keywords": ["sandbox", "proxy", "inspector", "cloudflare", "tunnel", "http"]
}
